{
  "respectGitignore": true,
  "env": {
    "CLAUDE_CODE_SHELL": "/opt/homebrew/bin/fish",
    "PROJECTS_DIRECTORY": "~/Documents/Projects"
  },
  "attribution": {
    "commit": "🤖 Generated with Claude Code\n\nCo-Authored-By: Claude <noreply@anthropic.com>",
    "pr": "🤖 Generated with Claude Code"
  },
  "permissions": {
    "allow": [
      "Bash(go build*)",
      "Bash(go test*)",
      "Bash(go run*)",
      "Bash(docker ps*)",
      "Bash(docker logs*)",
      "Bash(docker build*)",
      "Bash(docker compose*)",
      "Bash(terraform plan*)",
      "Bash(terraform validate*)",
      "Bash(terraform fmt*)",
      "Bash(git *)"
    ],
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf*)",
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)",
      "Bash(docker stop*)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "codex@openai-codex": true,
    "gitkraken-hooks@gitkraken": true,
    "shopify-plugin@shopify-ai-toolkit": true
  },
  "extraKnownMarketplaces": {
    "gitkraken": {
      "source": {
        "source": "directory",
        "path": "/Users/gowizzard/.claude/plugins/marketplaces/gitkraken"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "shopify-ai-toolkit": {
      "source": {
        "source": "github",
        "repo": "Shopify/shopify-ai-toolkit"
      }
    }
  },
  "language": "german",
  "agentPushNotifEnabled": true,
  "voiceEnabled": true,
  "tui": "fullscreen"
}
